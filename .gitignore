# ============================================
# Claude Code 本地配置
# ============================================
.claude/

# ============================================
# IDE 编辑器
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ============================================
# 操作系统
# ============================================
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/
env/
.eggs/

# ============================================
# Node.js (如有)
# ============================================
node_modules/
package-lock.json

# ============================================
# 日志与临时文件
# ============================================
*.log
*.tmp
*.temp
*.swp
*.bak
*.orig

# ============================================
# 测试输出（生成文件不提交，但保留 .gitkeep 目录结构）
# ============================================
*.jtl

# 报告（排除生成内容，保留目录占位）
test-scripts/ui-tests/reports/*
!test-scripts/ui-tests/reports/.gitkeep

# 截图（排除图片，保留目录占位）
screenshots/**/*.png
screenshots/**/*.jpg
screenshots/**/*.jpeg
screenshots/**/*.gif
screenshots/**/*.bmp

# 测试结果
test-results/*
test-reports/*
!test-results/.gitkeep
!test-reports/.gitkeep
